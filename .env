# ============================================================================
# Base URLs for Automation Cloud/Suite. ${UIPATH_APP_URL} and 
# ${UIPATH_APP_REDIRECT_URI} are used in the frontend application for API 
# calls and OAuth redirection, respectively. The variable values are created 
# when you run the 'uipath register app' command from npm
# ----------------------------------------------------------------------------
VITE_UIPATH_BASE_URL=${UIPATH_BASE_URL}
VITE_UIPATH_APP_URL=${UIPATH_APP_URL}
VITE_UIPATH_REDIRECT_URI=${UIPATH_APP_REDIRECT_URI}
VITE_UIPATH_ORG_NAME=kristoferhoch
VITE_UIPATH_TENANT_NAME=clientsuccess_npe


# ============================================================================
# VITE_UIPATH OAuth Configuration
# ----------------------------------------------------------------------------

# EXTERNAL_APP_NAME to easily identify the External App configuration
VITE_UIPATH_EXTERNAL_APP_NAME=hammer-coded-app
VITE_UIPATH_CLIENT_ID=9d546cbb-3658-4966-aee4-5daf70abbdba
VITE_UIPATH_SCOPE=${UIPATH_SCOPE_ORCHESTRATOR} ${UIPATH_SCOPE_DATAFABRIC}
UIPATH_SCOPE_ORCHESTRATOR=OR.Execution OR.Queues
UIPATH_SCOPE_DATAFABRIC=DataFabric.Schema.Read DataFabric.Data.Read DataFabric.Data.Write


# REDIRECT_URI is auto-detected from current URL
UIPATH_BASE_URL=https://staging.api.uipath.com
UIPATH_APP_URL=https://staging.uipath.com
UIPATH_APP_REDIRECT_URI=http://localhost:3000
