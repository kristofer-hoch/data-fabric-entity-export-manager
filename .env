# ============================================================================
# Base URLs for Automation Cloud/Suite. ${UIPATH_APP_URL} and 
# ${UIPATH_APP_REDIRECT_URI} are used in the frontend application for API 
# calls and OAuth redirection, respectively. The variable values are created 
# when you run the 'uipath register app' command from npm
# ----------------------------------------------------------------------------
VITE_UIPATH_BASE_URL=${UIPATH_BASE_URL}
VITE_UIPATH_APP_URL=${UIPATH_APP_URL}
VITE_UIPATH_REDIRECT_URI=${UIPATH_APP_REDIRECT_URI}
VITE_UIPATH_ORG_NAME=your-automation-cloud-organization-name
VITE_UIPATH_TENANT_NAME=your-automation-cloud-tenant-name

# ============================================================================
# MINIMUM SCOPES REQUIRED TO RUN the APPLICATION.
# DataFabric.Schema.Read DataFabric.Data.Read DataFabric.Data.Write
# ----------------------------------------------------------------------------
VITE_UIPATH_EXTERNAL_APP_NAME=the-external-application-name
VITE_UIPATH_CLIENT_ID=the-client-id-of-the-external-application
VITE_UIPATH_SCOPE=DataFabric.Schema.Read DataFabric.Data.Read DataFabric.Data.Write

# ============================================================================
# UIPATH_BASE_URL and UIPATH_APP_URL are used in the frontend application for 
# API calls and OAuth redirection, respectively. They must conform to each 
# other.
# ----------------------------------------------------------------------------
# BASE_URL                               APP_URL
# ------------------------------------   ------------------------------------
# https://alpha.api.uipath.com           https://alpha.uipath.com
# https://cloud.uipath.com               https://cloud.uipath.com
# https://staging.api.uipath.com         https://staging.uipath.com
# ----------------------------------------------------------------------------
UIPATH_BASE_URL=https://staging.api.uipath.com
UIPATH_APP_URL=https://staging.uipath.com
UIPATH_APP_REDIRECT_URI=http://localhost:3000
